# ── Обязательное ───────────────────────────────────────────────
# Токен Telegram-бота от @BotFather
TELEGRAM_TOKEN=
# Ключ OpenAI-совместимого API (RouterAI / OpenAI / Codex Sale и т.п.)
AI_API_KEY=
# Telegram ID администраторов (через запятую или пробел)
ADMIN_IDS=

# ── Провайдер и модель (значения по умолчанию) ──────────────────
AI_BASE_URL=https://routerai.ru/api/v1
AI_MODEL=anthropic/claude-opus-4-7

# ── Доступ ──────────────────────────────────────────────────────
# 1 — бот открыт для всех, 0 — только админы и разрешённые пользователи
PUBLIC_ACCESS=0

# ── Cloudflare (необязательно) ──────────────────────────────────
# API Token с правами Zone:Read + DNS:Edit (My Profile → API Tokens → Edit zone DNS).
# Можно также задать прямо в боте: ☁️ Cloudflare → 🔑 Задать токен.
CLOUDFLARE_API_TOKEN=

# ── Безопасность ────────────────────────────────────────────────
# Постоянный ключ для шифрования паролей серверов на диске.
# Задайте свою длинную случайную строку и не меняйте её после старта.
SERVER_PASSWORD_KEY=

# ── Лимиты (необязательно, есть значения по умолчанию) ──────────
# MAX_OUTPUT=4000
# MAX_FILE_SIZE=200000
# MAX_HISTORY_CHARS=60000
# AUTO_CONTINUE_LIMIT=3
# MAX_AGENT_STEPS=20
# SESSION_TTL_DAYS=14

# ── Мониторинг (необязательно) ──────────────────────────────────
# SERVICE_MONITOR_ENABLED=1
# SERVICE_MONITOR_INTERVAL=60
